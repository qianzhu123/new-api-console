{
  "manifest_version": 3,
  "name": "qiandao Account Import Helper",
  "version": "1.0.0",
  "description": "Collect new-api/sub2api account import JSON from the current logged-in site for the local qiandao console.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "qiandao 导入",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
